# =============================================================================
# SaaS Starter — environment variables
#
# Copy this file to `.env.local` (Next.js will load it automatically in dev) and
# fill in the values. NEVER commit `.env.local`.
#
# All NEXT_PUBLIC_* values are exposed to the browser. Everything else stays
# server-side only.
# =============================================================================

# ---- App ---------------------------------------------------------------------
# Used by Stripe success_url / cancel_url and other absolute-URL builders.
# In production set this to your real domain (e.g. https://app.example.com).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- Clerk (https://dashboard.clerk.com) -------------------------------------
# Create an application → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhooks → endpoint signing secret (the value Clerk shows after you create the
# webhook). Used in src/app/api/webhooks/clerk/route.ts to verify Svix signatures.
CLERK_WEBHOOK_SECRET=whsec_...

# ---- Supabase (https://supabase.com/dashboard) -------------------------------
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
# Service-role key bypasses RLS; never expose to the browser. The starter only
# uses it from server components / API routes (lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---- Stripe (https://dashboard.stripe.com) -----------------------------------
# Developers → API keys. Use a test mode key while you're building.
STRIPE_SECRET_KEY=sk_test_...
# Developers → Webhooks → endpoint signing secret. While developing locally you
# get this from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`.
STRIPE_WEBHOOK_SECRET=whsec_...
